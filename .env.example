# Appium Android Config
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_PLATFORM_VERSION=11.0
ANDROID_APP_PACKAGE=com.example.webapp
ANDROID_APP_ACTIVITY=.MainActivity
