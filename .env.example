PORT=5000
FRONTEND_URL=http://localhost:5173/
BACKEND_URL=http://localhost:5000
VITE_BACKEND_URL=http://localhost:5000

# Security Secrets (DO NOT commit real values to Git)
JWT_SECRET=your_jwt_secret_key_here
