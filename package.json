{
  "name": "prototype",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "vite --host",
    "start:backend": "node server.cjs",
    "start:frontend": "npm run dev",
    "start:all": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:web:mocha": "mocha --require tests/selenium/utils/testSetup.js \"tests/selenium/testcases/*.test.js\" --timeout 300000",
    "test:web": "start-server-and-test start:all http://localhost:5173 test:web:mocha",
    "test:mobile": "mocha --require tests/appium/utils/testSetup.js \"tests/appium/testcases/*.test.js\" --timeout 300000",
    "test:all": "npm run test:web && npm run test:mobile"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.14.0",
    "mongoose": "^9.7.0",
    "multer": "^2.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@wdio/cli": "^9.28.0",
    "autoprefixer": "^10.5.0",
    "axios": "^1.17.0",
    "chai": "^6.2.2",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "exceljs": "^4.4.0",
    "globals": "^17.6.0",
    "mocha": "^11.7.6",
    "postcss": "^8.5.14",
    "selenium-webdriver": "^4.44.0",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "webdriverio": "^9.28.0",
    "winston": "^3.19.0"
  }
}
